# === DRAIN (required) ===
PROVIDER_PRIVATE_KEY=0x_your_private_key_here

# === Replicate (required) ===
REPLICATE_API_TOKEN=r8_your_replicate_token

# === Pricing ===
MARKUP_PERCENT=50

# === Registry Sync ===
SYNC_INTERVAL_HOURS=24
REGISTRY_PATH=./data/registry.json
# Comma-separated collection slugs to sync (leave empty for defaults)
# SYNC_COLLECTIONS=official,text-to-image,image-to-video,language-models

# === Prediction ===
MAX_PREDICTION_TIMEOUT_MS=600000
PREDICTION_POLL_INTERVAL_MS=3000

# === Network ===
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY
PORT=3000
HOST=0.0.0.0
CHAIN_ID=137
PROVIDER_NAME=HS58-Replicate
CLAIM_THRESHOLD=50000
AUTO_CLAIM_INTERVAL_MINUTES=10
AUTO_CLAIM_BUFFER_SECONDS=3600
STORAGE_PATH=./data/vouchers.json
